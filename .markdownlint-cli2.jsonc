// markdownlint-cli2 config — see https://github.com/DavidAnson/markdownlint-cli2
{
  "globs": ["**/*.md"],
  "ignores": ["node_modules", "vendor"],
  "config": {
    "default": true,
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD033": false,
    "MD036": false,
    "MD041": false,
  },
}
