{
  "name": "trueview/watchtower-theme",
  "description": "Dev tooling (PHPCS/WPCS + PHPStan) for the True View Watchtower WordPress theme",
  "license": "GPL-2.0-or-later",
  "type": "project",
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "ergebnis/composer-normalize": "^2.52",
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "php-stubs/wordpress-stubs": "^6.9",
    "phpcompatibility/php-compatibility": "^9.3",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "squizlabs/php_codesniffer": "^3.13",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-coding-standards/wpcs": "^3.2"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "analyse": "phpstan analyse --memory-limit=4G",
    "fix": "phpcbf",
    "lint": "phpcs",
    "lint:syntax": "parallel-lint --no-progress --exclude vendor --exclude node_modules ."
  }
}
