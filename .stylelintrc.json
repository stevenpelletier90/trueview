{
  "extends": ["stylelint-config-standard", "stylelint-config-recess-order"],
  "rules": {
    "selector-class-pattern": ["^[a-z][a-z0-9]*([_-]+[a-z0-9]+)*$", { "message": "Expected class selector to be kebab-case" }],
    "property-no-vendor-prefix": [true, { "ignoreProperties": ["font-smoothing", "-webkit-font-smoothing", "backdrop-filter", "-webkit-backdrop-filter"] }],
    "media-feature-range-notation": "prefix",
    "no-duplicate-selectors": [true, { "disallowInList": false }],
    "declaration-block-no-duplicate-properties": [true, { "ignore": ["consecutive-duplicates-with-different-values"] }],
    "selector-max-compound-selectors": 5
  }
}
