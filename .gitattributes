# Force LF line endings for all text files (matches .editorconfig)
* text=auto eol=lf

# Binary assets — never line-ending-convert or text-diff these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.pdf   binary
