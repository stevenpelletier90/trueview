<?xml version="1.0"?>
<ruleset name="True View Watchtower">
    <description>PHP_CodeSniffer configuration for the True View Watchtower WordPress theme</description>

    <!-- Scan the theme folder -->
    <file>trueview-watchtower</file>

    <!-- Only scan PHP files -->
    <arg name="extensions" value="php"/>

    <!-- Exclude third party code and non-theme dev scripts -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tools/*</exclude-pattern>

    <!-- Show progress and use colors -->
    <arg value="p"/>
    <arg name="colors"/>

    <!-- Cache results for faster subsequent runs -->
    <arg name="cache" value=".phpcs-cache"/>

    <!-- No memory ceiling -->
    <ini name="memory_limit" value="-1"/>

    <!-- WordPress coding standards -->
    <rule ref="WordPress"/>

    <!-- PHP cross-version compatibility (matches the theme's "Requires PHP: 7.4") -->
    <config name="testVersion" value="7.4-8.5"/>
    <rule ref="PHPCompatibility"/>

    <!-- Theme text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="trueview-watchtower"/>
            </property>
        </properties>
    </rule>

    <!-- Recognised global prefixes for functions, hooks, and globals -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="trueview"/>
            </property>
        </properties>
    </rule>
</ruleset>
